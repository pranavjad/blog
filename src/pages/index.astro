---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";
import { getCollection } from "astro:content";

interface Item {
  name: string;
  description: string;
  url: string;
  isExternal: boolean;
}

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const projects: Item[] = [
  {
    name: "pRRTC",
    description:
      "GPU accelerated motion planning for robotic manipulators. Published @ ICRA 2026.",
    url: "https://github.com/CoMMALab/pRRTC",
    isExternal: true,
  },
  {
    name: "mlx-gpt2",
    description:
      "A from-scratch implementation of GPT-2 optimized for Apple silicon.",
    url: "https://github.com/pranavjad/mlx-gpt2",
    isExternal: true,
  },
  {
    name: "music transformer",
    description: "Training a transformer to generate MIDI piano compositions.",
    url: "https://github.com/pranavjad/music-transformer",
    isExternal: true,
  },
];

const socials: Item[] = [
  {
    name: "X",
    description: "Follow Pranav on X",
    url: "https://x.com/pranav_jad",
    isExternal: true,
  },
  {
    name: "GitHub",
    description: "View Pranav's GitHub",
    url: "https://github.com/pranavjad",
    isExternal: true,
  },
  {
    name: "Email",
    description: "Email Pranav",
    url: "mailto:pra168109@gmail.com",
    isExternal: false,
  },
  {
    name: "LinkedIn",
    description: "Connect with Pranav on LinkedIn",
    url: "https://www.linkedin.com/in/pjad/",
    isExternal: true,
  },
];
---

<Layout>
  <main class="[&_p]:text-muted-foreground">
    <p>
      I am junior at Purdue University studying Computer Science. Currently, I
      am working on pushing the limits of edge AI inference at <Link
        url="https://maticrobots.com/">Matic Robots</Link
      >. At school I also do research with <Link url="https://commalab.org/"
        >CoMMA Lab</Link
      >.
    </p>
    <div class="mt-6 mb-16 flex gap-3">
      {
        socials.map((social) => (
          <a
            class="text-muted-foreground hover:bg-muted hover:text-foreground rounded-md p-2 no-underline transition-colors"
            href={social.url}
            target={social.isExternal ? "_blank" : undefined}
            rel={social.isExternal ? "noopener noreferrer" : undefined}
            aria-label={social.description}
            title={social.name}
          >
            {social.name === "X" && (
              <svg
                aria-hidden="true"
                class="size-5"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817-5.963 6.817H1.684l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z" />
              </svg>
            )}
            {social.name === "GitHub" && (
              <svg
                aria-hidden="true"
                class="size-5"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.807 1.305 3.492.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23A11.47 11.47 0 0 1 12 6.097c1.02.005 2.045.138 3.003.404 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                />
              </svg>
            )}
            {social.name === "Email" && (
              <svg
                aria-hidden="true"
                class="size-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            )}
            {social.name === "LinkedIn" && (
              <svg
                aria-hidden="true"
                class="size-5"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M20.447 20.452h-3.554v-5.568c0-1.328-.027-3.037-1.85-3.037-1.853 0-2.136 1.447-2.136 2.941v5.664H9.354V9h3.414v1.561h.049c.476-.9 1.637-1.85 3.368-1.85 3.602 0 4.267 2.371 4.267 5.455v6.286h-.005ZM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124ZM7.114 20.452H3.558V9h3.556v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z" />
              </svg>
            )}
          </a>
        ))
      }
    </div>
    <h2>Projects</h2>
    <div class="flex flex-col gap-2">
      {
        projects.map((project) => (
          <a
            class="hover:bg-muted -mx-3 flex flex-col rounded-md px-3 py-2 no-underline"
            href={project.url}
            target={project.isExternal ? "_blank" : undefined}
            rel={project.isExternal ? "noopener noreferrer" : undefined}
          >
            <span>{project.name}</span>
            <span class="text-muted-foreground">{project.description}</span>
          </a>
        ))
      }
    </div>
    <h2>Writing</h2>
    <div class="flex flex-col gap-2">
      {
        posts.map((post) => (
          <a
            class="hover:bg-muted -mx-3 flex flex-col rounded-md px-3 py-2 no-underline"
            href={`/blog/${post.id}`}
          >
            <span>{post.data.title}</span>
            <span class="text-muted-foreground">{post.data.description}</span>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
