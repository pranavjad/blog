---
const BM = 64;
const BN = 64;
const BK = 8;
// A_thread_layout: (8, 8) row-major; B_thread_layout: (1, 64) row-major.
const A_TL_ROWS = 8;
const A_TL_COLS = 8;
const B_TL_ROWS = 1;
const B_TL_COLS = 64;

const CELL_SIZE = 6;

const gA_W = BK * CELL_SIZE; // 32
const gA_H = BM * CELL_SIZE; // 256
const gB_W = BN * CELL_SIZE; // 256
const gB_H = BK * CELL_SIZE; // 32

// Tile dims in pixels
const A_TILE_W = A_TL_COLS * CELL_SIZE; // 32
const A_TILE_H = A_TL_ROWS * CELL_SIZE; // 32
const B_TILE_W = B_TL_COLS * CELL_SIZE; // 256
const B_TILE_H = B_TL_ROWS * CELL_SIZE; // 4

// Number of tiles in each tensor
const A_TILE_ROWS = BM / A_TL_ROWS; // 8
const A_TILE_COLS = BK / A_TL_COLS; // 1
const B_TILE_ROWS = BK / B_TL_ROWS; // 8
const B_TILE_COLS = BN / B_TL_COLS; // 1

const GAP = 64;
const SVG_WIDTH = 820;
const layoutWidth = gA_W + GAP + gB_W; // 32 + 24 + 256 = 312
const gA_X = (SVG_WIDTH - layoutWidth) / 2;
const gB_X = gA_X + gA_W + GAP;
const TOP_Y = 28;
const gA_Y = TOP_Y;
// Vertically center gB on gA's center.
const gB_Y = TOP_Y + (gA_H - gB_H) / 2;

const matricesBottom = gA_Y + gA_H;
const TEXT_BLOCK_TOP = matricesBottom + 36;
const LINE_HEIGHT = 22;
const SWATCH_SIZE = 12;
const SWATCH_GAP = 8;
const SVG_HEIGHT = TEXT_BLOCK_TOP + LINE_HEIGHT * 2 + 8;

// Default thread index (must be in [0, 64))
const FEATURED_TID = 17;

// Per-tile partition rectangles for gA and gB.
const aTiles = Array.from({ length: A_TILE_ROWS }, (_, i) => i);
const bTiles = Array.from({ length: B_TILE_ROWS }, (_, i) => i);

// Hitbox cells over each tensor (one per cell of the tensor).
const gACells = Array.from(
  { length: BM * BK },
  (_, i) => ({ row: Math.floor(i / BK), col: i % BK }),
);
const gBCells = Array.from(
  { length: BK * BN },
  (_, i) => ({ row: Math.floor(i / BN), col: i % BN }),
);
---

<figure
  class="local-partition-viz"
  data-cell-size={CELL_SIZE}
  data-a-tile-w={A_TILE_W}
  data-a-tile-h={A_TILE_H}
  data-b-tile-w={B_TILE_W}
  data-b-tile-h={B_TILE_H}
  data-a-tl-cols={A_TL_COLS}
  data-b-tl-cols={B_TL_COLS}
  data-ga-x={gA_X}
  data-ga-y={gA_Y}
  data-gb-x={gB_X}
  data-gb-y={gB_Y}
  data-text-line1-y={TEXT_BLOCK_TOP + LINE_HEIGHT * 0.5}
  data-text-line2-y={TEXT_BLOCK_TOP + LINE_HEIGHT * 1.5}
  data-svg-width={SVG_WIDTH}
  data-swatch-size={SWATCH_SIZE}
  data-swatch-gap={SWATCH_GAP}
  data-featured-tid={FEATURED_TID}
>
  <svg
    class="local-partition-panel"
    width={SVG_WIDTH}
    height={SVG_HEIGHT}
    viewBox={`0 0 ${SVG_WIDTH} ${SVG_HEIGHT}`}
    role="img"
    aria-label="local_partition visualization for the 2D blocktiling matmul"
    aria-describedby="local-partition-viz-desc"
  >
    <desc id="local-partition-viz-desc">
      Hover a cell in gA or gB to set threadIdx.x. Each thread receives one
      cell per tile — the highlighted cells are the elements that thread is
      responsible for loading from gmem to smem.
    </desc>

    <defs>
      <pattern
        id="lpv-cell-grid"
        width={CELL_SIZE}
        height={CELL_SIZE}
        patternUnits="userSpaceOnUse"
      >
        <path d={`M ${CELL_SIZE} 0 L 0 0 0 ${CELL_SIZE}`}></path>
      </pattern>
      <pattern
        id="lpv-a-tile-grid"
        width={A_TILE_W}
        height={A_TILE_H}
        patternUnits="userSpaceOnUse"
      >
        <path d={`M ${A_TILE_W} 0 L 0 0 0 ${A_TILE_H}`}></path>
      </pattern>
      <pattern
        id="lpv-b-tile-grid"
        width={B_TILE_W}
        height={B_TILE_H}
        patternUnits="userSpaceOnUse"
      >
        <path d={`M ${B_TILE_W} 0 L 0 0 0 ${B_TILE_H}`}></path>
      </pattern>
    </defs>

    <!-- gA: tall (BM x BK), tiled by A_thread_layout (8, 8). -->
    <g class="matrix ga" transform={`translate(${gA_X} ${gA_Y})`}>
      <rect class="matrix-fill" width={gA_W} height={gA_H}></rect>
      <rect class="cell-grid" width={gA_W} height={gA_H}></rect>
      <g class="ga-partition">
        {
          aTiles.map((tileRow) => (
            <rect
              class="partition-cell partition-cell-a"
              data-tile-row={tileRow}
              x="0"
              y={tileRow * A_TILE_H}
              width={CELL_SIZE}
              height={CELL_SIZE}
            />
          ))
        }
      </g>
      <rect class="tile-grid tile-grid-a" width={gA_W} height={gA_H}></rect>
      {
        gACells.map((c) => (
          <rect
            class="ga-hitbox"
            data-cell-row={c.row}
            data-cell-col={c.col}
            x={c.col * CELL_SIZE}
            y={c.row * CELL_SIZE}
            width={CELL_SIZE}
            height={CELL_SIZE}
          />
        ))
      }
      <rect class="matrix-border" width={gA_W} height={gA_H}></rect>
      <text class="matrix-label" x="6" y="15">gA</text>
      <text class="axis-label" x={gA_W / 2} y={gA_H + 14}>BK = {BK}</text>
      <text class="axis-label vertical" x="-22" y={gA_H / 2}>BM = {BM}</text>
    </g>

    <!-- gB: wide (BK x BN), tiled by B_thread_layout (1, 64). -->
    <g class="matrix gb" transform={`translate(${gB_X} ${gB_Y})`}>
      <rect class="matrix-fill" width={gB_W} height={gB_H}></rect>
      <rect class="cell-grid" width={gB_W} height={gB_H}></rect>
      <g class="gb-partition">
        {
          bTiles.map((tileRow) => (
            <rect
              class="partition-cell partition-cell-b"
              data-tile-row={tileRow}
              x="0"
              y={tileRow * B_TILE_H}
              width={CELL_SIZE}
              height={CELL_SIZE}
            />
          ))
        }
      </g>
      <rect class="tile-grid tile-grid-b" width={gB_W} height={gB_H}></rect>
      {
        gBCells.map((c) => (
          <rect
            class="gb-hitbox"
            data-cell-row={c.row}
            data-cell-col={c.col}
            x={c.col * CELL_SIZE}
            y={c.row * CELL_SIZE}
            width={CELL_SIZE}
            height={CELL_SIZE}
          />
        ))
      }
      <rect class="matrix-border" width={gB_W} height={gB_H}></rect>
      <text class="matrix-label" x="6" y="15">gB</text>
      <text class="axis-label vertical" x="-22" y={gB_H / 2}>BK = {BK}</text>
      <text class="axis-label" x={gB_W / 2} y={gB_H + 14}>BN = {BN}</text>
    </g>

    <!-- Code lines -->
    <rect
      class="call-square call-square-a"
      width={SWATCH_SIZE}
      height={SWATCH_SIZE}></rect>
    <text class="call-text call-text-a" dominant-baseline="middle">
      <tspan>gA_to_r = local_partition(gA, A_thread_layout (8, 8), threadIdx.x = </tspan
      ><tspan class="tid-label">17</tspan><tspan>)  </tspan
      ><tspan class="comment">// shape: (8, 1, 8)</tspan>
    </text>

    <rect
      class="call-square call-square-b"
      width={SWATCH_SIZE}
      height={SWATCH_SIZE}></rect>
    <text class="call-text call-text-b" dominant-baseline="middle">
      <tspan>gB_to_r = local_partition(gB, B_thread_layout (1, 64), threadIdx.x = </tspan
      ><tspan class="tid-label">17</tspan><tspan>)  </tspan
      ><tspan class="comment">// shape: (8, 1, 8)</tspan>
    </text>
  </svg>
</figure>

<script>
  const figures = document.querySelectorAll(".local-partition-viz");

  figures.forEach((figure) => {
    const el = figure as HTMLElement;
    const cellSize = Number(el.dataset.cellSize);
    const aTileH = Number(el.dataset.aTileH);
    const bTileH = Number(el.dataset.bTileH);
    const aTLCols = Number(el.dataset.aTlCols);
    const bTLCols = Number(el.dataset.bTlCols);
    const textY = [
      Number(el.dataset.textLine1Y),
      Number(el.dataset.textLine2Y),
    ];
    const svgWidth = Number(el.dataset.svgWidth);
    const swatchSize = Number(el.dataset.swatchSize);
    const swatchGap = Number(el.dataset.swatchGap);
    const featuredTid = Number(el.dataset.featuredTid);

    const aPartitionCells = figure.querySelectorAll<SVGRectElement>(
      ".partition-cell-a",
    );
    const bPartitionCells = figure.querySelectorAll<SVGRectElement>(
      ".partition-cell-b",
    );

    const swatches = [
      figure.querySelector<SVGRectElement>(".call-square-a"),
      figure.querySelector<SVGRectElement>(".call-square-b"),
    ];
    const texts = [
      figure.querySelector<SVGTextElement>(".call-text-a"),
      figure.querySelector<SVGTextElement>(".call-text-b"),
    ];
    const tidLabels = figure.querySelectorAll(".tid-label");

    function layoutLines() {
      let maxWidth = 0;
      texts.forEach((t) => {
        if (t) maxWidth = Math.max(maxWidth, t.getBBox().width);
      });
      const total = swatchSize + swatchGap + maxWidth;
      const startX = (svgWidth - total) / 2;
      texts.forEach((text, idx) => {
        const swatch = swatches[idx];
        if (!text || !swatch) return;
        const sy = textY[idx] - swatchSize / 2;
        swatch.setAttribute("x", String(startX));
        swatch.setAttribute("y", String(sy));
        text.setAttribute("x", String(startX + swatchSize + swatchGap));
        text.setAttribute("y", String(textY[idx]));
      });
    }

    function update(tid: number) {
      // A_thread_layout (8, 8) row-major: tid -> (innerRow, innerCol)
      const aInnerRow = Math.floor(tid / aTLCols);
      const aInnerCol = tid % aTLCols;
      // B_thread_layout (1, 64) row-major: tid -> (0, tid)
      const bInnerRow = 0;
      const bInnerCol = tid % bTLCols;

      aPartitionCells.forEach((cell) => {
        const tileRow = Number(cell.dataset.tileRow);
        cell.setAttribute("x", String(aInnerCol * cellSize));
        cell.setAttribute(
          "y",
          String(tileRow * aTileH + aInnerRow * cellSize),
        );
      });
      bPartitionCells.forEach((cell) => {
        const tileRow = Number(cell.dataset.tileRow);
        cell.setAttribute("x", String(bInnerCol * cellSize));
        cell.setAttribute(
          "y",
          String(tileRow * bTileH + bInnerRow * cellSize),
        );
      });

      tidLabels.forEach((n) => (n.textContent = String(tid)));

      layoutLines();
    }

    figure
      .querySelectorAll<HTMLElement>(".ga-hitbox")
      .forEach((cell) => {
        cell.addEventListener("pointerenter", () => {
          const r = Number(cell.dataset.cellRow);
          const c = Number(cell.dataset.cellCol);
          // tid = (r % 8) * 8 + (c % 8), but BK=8 so c < 8 always.
          const tid = (r % 8) * aTLCols + (c % aTLCols);
          update(tid);
        });
      });
    figure
      .querySelectorAll<HTMLElement>(".gb-hitbox")
      .forEach((cell) => {
        cell.addEventListener("pointerenter", () => {
          const c = Number(cell.dataset.cellCol);
          // B_thread_layout (1, 64) row-major: tid = c % 64.
          const tid = c % bTLCols;
          update(tid);
        });
      });

    update(featuredTid);
  });
</script>

<style>
  .local-partition-viz {
    --viz-ink: color-mix(in oklab, var(--foreground) 80%, transparent);
    --viz-tile-grid: color-mix(in oklab, var(--foreground) 36%, transparent);
    --viz-cell-grid: color-mix(in oklab, var(--foreground) 10%, transparent);
    --viz-fill: color-mix(in oklab, var(--muted) 72%, transparent);
    --viz-a: oklch(0.72 0.18 65);
    --viz-b: oklch(0.68 0.19 230);
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 2rem 0;
  }

  .local-partition-panel {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .matrix-fill {
    fill: var(--viz-fill);
  }

  .cell-grid {
    fill: url("#lpv-cell-grid");
  }

  .tile-grid {
    pointer-events: none;
  }
  .tile-grid-a {
    fill: url("#lpv-a-tile-grid");
  }
  .tile-grid-b {
    fill: url("#lpv-b-tile-grid");
  }

  #lpv-cell-grid path {
    fill: none;
    stroke: var(--viz-cell-grid);
    stroke-width: 0.4;
  }

  #lpv-a-tile-grid path,
  #lpv-b-tile-grid path {
    fill: none;
    stroke: var(--viz-tile-grid);
    stroke-width: 0.9;
  }

  .matrix-border {
    fill: none;
    stroke: var(--viz-ink);
    stroke-width: 1.5;
    pointer-events: none;
  }

  .matrix-label {
    fill: var(--foreground);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    pointer-events: none;
    paint-order: stroke;
    stroke: var(--background);
    stroke-width: 3px;
    stroke-linejoin: round;
  }

  .comment {
    fill: var(--muted-foreground);
    white-space: pre;
  }

  .axis-label {
    fill: var(--muted-foreground);
    font-family: var(--font-mono);
    font-size: 10px;
    text-anchor: middle;
    pointer-events: none;
  }

  .vertical {
    transform-box: fill-box;
    transform-origin: center;
    rotate: -90deg;
  }

  .ga-hitbox,
  .gb-hitbox {
    fill: transparent;
    cursor: crosshair;
  }

  .partition-cell {
    pointer-events: none;
    stroke-width: 0.5;
  }
  .partition-cell-a {
    fill: oklch(0.72 0.18 65 / 0.7);
    stroke: var(--viz-a);
  }
  .partition-cell-b {
    fill: oklch(0.68 0.19 230 / 0.7);
    stroke: var(--viz-b);
  }

  .call-square {
    pointer-events: none;
    stroke-width: 1.5;
  }
  .call-square-a {
    fill: oklch(0.72 0.18 65 / 0.7);
    stroke: var(--viz-a);
  }
  .call-square-b {
    fill: oklch(0.68 0.19 230 / 0.7);
    stroke: var(--viz-b);
  }

  .call-text {
    fill: var(--foreground);
    font-family: var(--font-mono);
    font-size: 13px;
    pointer-events: none;
  }

  .call-text-a .tid-label {
    fill: var(--viz-a);
    font-weight: 700;
  }
  .call-text-b .tid-label {
    fill: var(--viz-b);
    font-weight: 700;
  }
</style>
