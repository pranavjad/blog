---
const TENSOR_DIM = 64;
const TILE_DIM = 8;
const MATRIX_SIZE = 256;
const TILE_COUNT = TENSOR_DIM / TILE_DIM;
const TILE_SIZE = MATRIX_SIZE / TILE_COUNT;
const CELL_SIZE = MATRIX_SIZE / TENSOR_DIM;

const SVG_WIDTH = 500;
const MATRIX_X = (SVG_WIDTH - MATRIX_SIZE) / 2;
const MATRIX_Y = 24;
const AXIS_BOTTOM_Y = MATRIX_Y + MATRIX_SIZE + 18;
const TEXT_CENTER_Y = AXIS_BOTTOM_Y + 26;
const SVG_HEIGHT = TEXT_CENTER_Y + 16;

const SWATCH_SIZE = 12;
const SWATCH_GAP = 8;

const cells = Array.from(
  { length: TENSOR_DIM * TENSOR_DIM },
  (_, index) => ({
    row: Math.floor(index / TENSOR_DIM),
    col: index % TENSOR_DIM,
  }),
);

const tilePositions = Array.from(
  { length: TILE_COUNT * TILE_COUNT },
  (_, i) => ({
    tileRow: Math.floor(i / TILE_COUNT),
    tileCol: i % TILE_COUNT,
  }),
);

const FEATURED_INNER_ROW = 0;
const FEATURED_INNER_COL = 0;
const FEATURED_INDEX = FEATURED_INNER_COL * TILE_DIM + FEATURED_INNER_ROW;
---

<figure
  class="local-partition-viz"
  data-matrix-x={MATRIX_X}
  data-matrix-y={MATRIX_Y}
  data-cell-size={CELL_SIZE}
  data-tile-size={TILE_SIZE}
  data-tile-dim={TILE_DIM}
  data-svg-width={SVG_WIDTH}
  data-text-center-y={TEXT_CENTER_Y}
  data-swatch-size={SWATCH_SIZE}
  data-swatch-gap={SWATCH_GAP}
  data-featured-inner-row={FEATURED_INNER_ROW}
  data-featured-inner-col={FEATURED_INNER_COL}
  data-featured-index={FEATURED_INDEX}
>
  <svg
    class="local-partition-panel"
    width={SVG_WIDTH}
    height={SVG_HEIGHT}
    viewBox={`0 0 ${SVG_WIDTH} ${SVG_HEIGHT}`}
    role="img"
    aria-label="local_partition visualization"
    aria-describedby="local-partition-viz-desc"
  >
    <desc id="local-partition-viz-desc">
      Hover a cell to highlight all cells at the same intra-tile position
      across every tile — that set is the local_partition.
    </desc>

    <defs>
      <pattern
        id="local-partition-tile-grid"
        width={TILE_SIZE}
        height={TILE_SIZE}
        patternUnits="userSpaceOnUse"
      >
        <path d={`M ${TILE_SIZE} 0 L 0 0 0 ${TILE_SIZE}`}></path>
      </pattern>
      <pattern
        id="local-partition-cell-grid"
        width={CELL_SIZE}
        height={CELL_SIZE}
        patternUnits="userSpaceOnUse"
      >
        <path d={`M ${CELL_SIZE} 0 L 0 0 0 ${CELL_SIZE}`}></path>
      </pattern>
    </defs>

    <g class="matrix" transform={`translate(${MATRIX_X} ${MATRIX_Y})`}>
      <rect class="matrix-fill" width={MATRIX_SIZE} height={MATRIX_SIZE}></rect>
      <rect
        class="cell-grid"
        width={MATRIX_SIZE}
        height={MATRIX_SIZE}></rect>
      <g class="partition-highlights">
        {
          tilePositions.map((tile) => (
            <rect
              class="partition-cell"
              data-tile-row={tile.tileRow}
              data-tile-col={tile.tileCol}
              x={tile.tileCol * TILE_SIZE + FEATURED_INNER_COL * CELL_SIZE}
              y={tile.tileRow * TILE_SIZE + FEATURED_INNER_ROW * CELL_SIZE}
              width={CELL_SIZE}
              height={CELL_SIZE}
            />
          ))
        }
      </g>
      <rect
        class="tile-grid"
        width={MATRIX_SIZE}
        height={MATRIX_SIZE}></rect>
      {
        cells.map((cell) => (
          <rect
            class="cell-hitbox"
            data-cell-row={cell.row}
            data-cell-col={cell.col}
            x={cell.col * CELL_SIZE}
            y={cell.row * CELL_SIZE}
            width={CELL_SIZE}
            height={CELL_SIZE}
          />
        ))
      }
      <rect class="matrix-border" width={MATRIX_SIZE} height={MATRIX_SIZE}
      ></rect>
      <text class="matrix-label" x="7" y="14">tensor</text>
      <text class="axis-label" x={MATRIX_SIZE / 2} y={MATRIX_SIZE + 18}
        >64</text
      >
      <text class="axis-label vertical" x="-18" y={MATRIX_SIZE / 2}>64</text>
    </g>

    <g class="connectors">
      {
        tilePositions.map((tile) => (
          <line
            class="connector"
            data-tile-row={tile.tileRow}
            data-tile-col={tile.tileCol}
          />
        ))
      }
    </g>

    <rect
      class="call-square"
      width={SWATCH_SIZE}
      height={SWATCH_SIZE}></rect>
    <text class="call-text" dominant-baseline="middle">
      <tspan> = local_partition(tensor, make_layout(8, 8), </tspan><tspan
        class="call-coord">0</tspan
      ><tspan>)</tspan>
    </text>
  </svg>
</figure>

<script>
  const figures = document.querySelectorAll(".local-partition-viz");

  figures.forEach((figure) => {
    const el = figure as HTMLElement;
    const matrixX = Number(el.dataset.matrixX);
    const matrixY = Number(el.dataset.matrixY);
    const cellSize = Number(el.dataset.cellSize);
    const tileSize = Number(el.dataset.tileSize);
    const tileDim = Number(el.dataset.tileDim);
    const svgWidth = Number(el.dataset.svgWidth);
    const textCenterY = Number(el.dataset.textCenterY);
    const swatchSize = Number(el.dataset.swatchSize);
    const swatchGap = Number(el.dataset.swatchGap);
    const featuredInnerRow = Number(el.dataset.featuredInnerRow);
    const featuredInnerCol = Number(el.dataset.featuredInnerCol);

    const partitionCells = figure.querySelectorAll<SVGRectElement>(
      ".partition-cell",
    );
    const connectors = figure.querySelectorAll<SVGLineElement>(".connector");
    const swatch = figure.querySelector<SVGRectElement>(".call-square");
    const text = figure.querySelector<SVGTextElement>(".call-text");
    const coord = figure.querySelector(".call-coord");

    function layout() {
      if (!text || !swatch) return null;
      const bbox = text.getBBox();
      const total = swatchSize + swatchGap + bbox.width;
      const startX = (svgWidth - total) / 2;
      const swatchX = startX;
      const swatchY = textCenterY - swatchSize / 2;
      swatch.setAttribute("x", String(swatchX));
      swatch.setAttribute("y", String(swatchY));
      const textX = startX + swatchSize + swatchGap;
      text.setAttribute("x", String(textX));
      text.setAttribute("y", String(textCenterY));
      return {
        swatchCenterX: swatchX + swatchSize / 2,
        swatchCenterY: swatchY + swatchSize / 2,
      };
    }

    function update(innerRow: number, innerCol: number) {
      const index = innerCol * tileDim + innerRow;
      partitionCells.forEach((cell) => {
        const tileRow = Number(cell.dataset.tileRow);
        const tileCol = Number(cell.dataset.tileCol);
        cell.setAttribute(
          "x",
          String(tileCol * tileSize + innerCol * cellSize),
        );
        cell.setAttribute(
          "y",
          String(tileRow * tileSize + innerRow * cellSize),
        );
      });
      if (coord) coord.textContent = String(index);

      const swatchPos = layout();
      if (!swatchPos) return;

      connectors.forEach((line) => {
        const tileRow = Number(line.dataset.tileRow);
        const tileCol = Number(line.dataset.tileCol);
        const cx =
          matrixX +
          tileCol * tileSize +
          innerCol * cellSize +
          cellSize / 2;
        const cy =
          matrixY +
          tileRow * tileSize +
          innerRow * cellSize +
          cellSize / 2;
        line.setAttribute("x1", String(cx));
        line.setAttribute("y1", String(cy));
        line.setAttribute("x2", String(swatchPos.swatchCenterX));
        line.setAttribute("y2", String(swatchPos.swatchCenterY));
      });
    }

    figure
      .querySelectorAll<HTMLElement>("[data-cell-row][data-cell-col]")
      .forEach((cell) => {
        cell.addEventListener("pointerenter", () => {
          const cellRow = Number(cell.dataset.cellRow);
          const cellCol = Number(cell.dataset.cellCol);
          update(cellRow % tileDim, cellCol % tileDim);
        });
      });

    update(featuredInnerRow, featuredInnerCol);
  });
</script>

<style>
  .local-partition-viz {
    --viz-ink: color-mix(in oklab, var(--foreground) 80%, transparent);
    --viz-grid: color-mix(in oklab, var(--foreground) 20%, transparent);
    --viz-tile-grid: color-mix(in oklab, var(--foreground) 36%, transparent);
    --viz-cell-grid: color-mix(in oklab, var(--foreground) 10%, transparent);
    --viz-fill: color-mix(in oklab, var(--muted) 72%, transparent);
    --viz-block: oklch(0.72 0.18 65);
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 2rem 0;
  }

  .local-partition-panel {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .matrix-fill {
    fill: var(--viz-fill);
  }

  .cell-grid {
    fill: url("#local-partition-cell-grid");
  }

  .tile-grid {
    fill: url("#local-partition-tile-grid");
    pointer-events: none;
  }

  #local-partition-cell-grid path {
    fill: none;
    stroke: var(--viz-cell-grid);
    stroke-width: 0.4;
  }

  #local-partition-tile-grid path {
    fill: none;
    stroke: var(--viz-tile-grid);
    stroke-width: 0.9;
  }

  .matrix-border {
    fill: none;
    stroke: var(--viz-ink);
    stroke-width: 2;
    pointer-events: none;
  }

  .matrix-label {
    fill: var(--foreground);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    pointer-events: none;
  }

  .axis-label {
    fill: var(--muted-foreground);
    font-family: var(--font-mono);
    font-size: 9px;
    text-anchor: middle;
    pointer-events: none;
  }

  .vertical {
    transform-box: fill-box;
    transform-origin: center;
    rotate: -90deg;
  }

  .cell-hitbox {
    fill: transparent;
    cursor: crosshair;
  }

  .partition-cell {
    fill: oklch(0.72 0.18 65 / 0.55);
    stroke: var(--viz-block);
    stroke-width: 0.5;
    pointer-events: none;
  }

  .call-square {
    fill: oklch(0.72 0.18 65 / 0.55);
    stroke: var(--viz-block);
    stroke-width: 1.5;
    pointer-events: none;
  }

  .call-text {
    fill: var(--foreground);
    font-family: var(--font-mono);
    font-size: 13px;
    pointer-events: none;
  }

  .call-coord {
    fill: var(--viz-block);
    font-weight: 700;
  }

  .connector {
    stroke: oklch(0.72 0.18 65 / 0.18);
    stroke-width: 0.6;
    pointer-events: none;
  }
</style>
